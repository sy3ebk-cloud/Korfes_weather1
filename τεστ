<!DOCTYPE html>
<html lang="el">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Σταθμός APRS Weather</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #eceff1; margin: 0; padding: 20px; color: #333; }
        .container { max-width: 1000px; margin: auto; background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
        h1 { color: #2c3e50; text-align: center; border-bottom: 3px solid #3498db; padding-bottom: 10px; }
        
        /* Στυλ για τα Live Δεδομένα */
        .live-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 15px; margin: 20px 0; }
        .data-card { background: #f8f9fa; padding: 15px; border-radius: 10px; border-left: 5px solid #3498db; text-align: center; }
        .data-card h3 { margin: 0; font-size: 0.9em; color: #7f8c8d; text-transform: uppercase; }
        .data-card div { font-size: 1.5em; font-weight: bold; color: #2c3e50; margin-top: 5px; }

        /* Στυλ για Χάρτη και Γραφήματα */
        .media-section { margin-top: 30px; }
        .iframe-wrapper { margin-bottom: 25px; border-radius: 10px; overflow: hidden; border: 1px solid #ddd; }
        h2 { font-size: 1.2em; color: #2c3e50; margin-bottom: 10px; }
        .footer { text-align: center; font-size: 0.8em; color: #95a5a6; margin-top: 20px; }
    </style>
</head>
<body>

<div class="container">
    <h1>📡 Σταθμός: <span id="stat-name">Φόρτωση...</span></h1>

    <!-- LIVE DATA ΑΠΟ API -->
    <div class="live-grid">
        <div class="data-card"><h3>Θερμοκρασία</h3><div id="temp">--</div></div>
        <div class="data-card"><h3>Υγρασία</h3><div id="hum">--</div></div>
        <div class="data-card"><h3>Πίεση</h3><div id="press">--</div></div>
        <div class="data-card"><h3>Άνεμος</h3><div id="wind">--</div></div>
    </div>
    <p style="text-align:right; font-size:0.8em;">Τελευταία λήψη: <span id="last-update">--</span></p>

    <!-- ΧΑΡΤΗΣ -->
    <div class="media-section">
        <h2>📍 Τοποθεσία Σταθμού</h2>
        <div class="iframe-wrapper">
            <iframe width="100%" height="350" frameborder="0" src="https://aprs.fi"></iframe>
        </div>
    </div>

    <!-- ΓΡΑΦΗΜΑΤΑ -->
    <div class="media-section">
        <h2>📊 Ιστορικό Δεδομένων (24h)</h2>
        <div class="iframe-wrapper">
            <iframe width="100%" height="450" frameborder="0" src="https://aprs.fi"></iframe>
        </div>
    </div>

    <div class="footer">
        Data provided by <a href="https://aprs.fi" target="_blank">aprs.fi</a> | Updated every 10 min
    </div>
</div>

<script>
    // ΡΥΘΜΙΣΕΙΣ ΧΡΗΣΤΗ
    const API_KEY = '178783.zYZYiGKPgf5jTsS'; // Βάλε το API Key σου
    const CALLSIGN = 'SY3EBK-13'; // Βάλε το Callsign σου (π.χ. SV1XXX-13)

    async function updateWeather() {
        try {
            const url = `https://aprs.fi{CALLSIGN}&what=wx&apikey=${API_KEY}&format=json`;
            const response = await fetch(url);
            const data = await response.json();

            if (data.result === 'ok' && data.entries.length > 0) {
                const wx = data.entries[0];
                
                document.getElementById('stat-name').innerText = wx.name;
                document.getElementById('temp').innerText = (wx.temp || '--') + ' °C';
                document.getElementById('hum').innerText = (wx.humidity || '--') + ' %';
                document.getElementById('press').innerText = (wx.pressure || '--') + ' hPa';
                document.getElementById('wind').innerText = (wx.wind_speed || '0') + ' m/s';
                document.getElementById('last-update').innerText = new Date(wx.time * 1000).toLocaleTimeString('el-GR');
            }
        } catch (err) {
            console.error("Σφάλμα API:", err);
        }
    }

    // Εκτέλεση κατά το άνοιγμα
    updateWeather();
    // Ανανέωση κάθε 10 λεπτά (600.000 ms) για να μην μπλοκάρει το API Key
    setInterval(updateWeather, 600000);
</script>

</body>
</html>
